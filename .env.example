# WeChat Bot Configuration
WECHAT_BOT_NAME=AI助手
WECHAT_AUTO_ACCEPT_FRIEND=true
WECHAT_AUTO_REPLY_FRIEND=你好，我是AI助手，很高兴认识你！

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
OPENAI_SYSTEM_PROMPT=你是一个友好的微信聊天助手，请用中文回复用户消息。回答简洁、准确、有帮助。

# Bot Settings
BOT_ADMIN_WECHAT=your_wechat_id
BOT_REPLY_PRIVATE=true
BOT_REPLY_ROOM=true
BOT_ROOM_AT_ONLY=true

# Puppeteer Settings (for wechaty-puppet-puppeteer)
PUPPETEER_HEADLESS=true
PUPPETEER_EXEC_PATH=
